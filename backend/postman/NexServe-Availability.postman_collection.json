{
  "info": {
    "name": "NexServe Availability API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Patch Availability",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"vendorId\": \"{{vendorId}}\",\n  \"dayOfWeek\": 1,\n  \"startTime\": \"09:00\",\n  \"endTime\": \"17:00\",\n  \"isAvailable\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/availability",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "availability"]
        }
      }
    },
    {
      "name": "Get All Availability",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/availability",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "availability"]
        }
      }
    },
    {
      "name": "Get Availability By Vendor",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/availability/{{vendorId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "availability", "{{vendorId}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "vendorId",
      "value": ""
    }
  ]
}
